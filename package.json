{
  "name": "ht-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "vite",
    "build": "tsr generate && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsr generate && tsc -b --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "pnpm format && pnpm lint:fix",
    "test": "pnpm typecheck && pnpm format:check && pnpm lint",
    "routes:generate": "tsr generate",
    "api:types": "sh -c 'set -a; . ./.env; openapi-typescript ${VITE_API_BASE_URL}/api/docs/openapi.json -o src/shared/api/schema.d.ts'",
    "deploy:dry": "pnpm typecheck && pnpm lint && pnpm build"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-query-devtools": "5.100.14",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dayjs": "1.11.20",
    "i18next": "26.2.0",
    "i18next-browser-languagedetector": "8.2.1",
    "ky": "2.0.2",
    "lucide-react": "1.16.0",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "react-i18next": "17.0.8",
    "recharts": "3.8.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "9.36.0",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/router-cli": "1.167.10",
    "@tanstack/router-plugin": "1.168.11",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.14"
  }
}
